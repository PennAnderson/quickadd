# ============================================================================
# SNAP//QUICKADD — environment configuration
# Copy this file to ".env" and fill it in. NEVER commit the real .env
# (.env is gitignored). All secrets stay server-side; none reach the browser.
# ============================================================================

# ---- Runtime ----
# "production" enables prod paths: trust proxy (for Secure cookies behind a
# load balancer / HTTPS terminator), static caching, prod log line.
NODE_ENV=development
PORT=3000

# ---- Sessions ----
# Long random string used to sign the session cookie. REQUIRED in production.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string
# Set to "true" when the app is served over HTTPS so the cookie is Secure-only.
# (With NODE_ENV=production behind a proxy, also set this true.)
COOKIE_SECURE=false

# ---- Snap Login Kit (Snapchat OAuth) ----
# Create an app at https://devportal.snap.com → Login Kit, then copy values here.
# If SNAP_CLIENT_ID is blank, the connect flow runs in DEMO MODE (simulated),
# so the app still works locally without Snap credentials.
SNAP_CLIENT_ID=
SNAP_CLIENT_SECRET=
# Must EXACTLY match a redirect URI registered in the Snap dev portal.
SNAP_REDIRECT_URI=http://localhost:3000/api/auth/callback
# Space-separated Login Kit scopes you enabled for the app.
SNAP_SCOPES=https://auth.snapchat.com/oauth2/api/user.display_name https://auth.snapchat.com/oauth2/api/user.bitmoji.avatar https://auth.snapchat.com/oauth2/api/user.external_id

# ---- Quick Add scanner (vision model) ----
# Required for the screenshot/video scanner. Get a key at https://console.anthropic.com
# Without it, the scanner is disabled (503) and the UI falls back to manual entry.
ANTHROPIC_API_KEY=
# Optional: override the vision model (defaults to claude-opus-4-8).
SCAN_MODEL=claude-opus-4-8

# ---- Email verification (SMTP via nodemailer) ----
# If SMTP_HOST is unset, verification runs in DEV mode: the link is shown in the
# UI and logged instead of emailed. Set these to send real verification emails.
# Works with any SMTP provider — examples:
#   SendGrid : host=smtp.sendgrid.net   port=587  user=apikey         pass=<API_KEY>
#   Resend   : host=smtp.resend.com     port=587  user=resend         pass=<API_KEY>
#   Mailgun  : host=smtp.mailgun.org    port=587  user=<smtp_login>   pass=<smtp_pass>
#   Postmark : host=smtp.postmarkapp.com port=587 user=<token>        pass=<token>
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="SNAP//QUICKADD <no-reply@yourdomain.com>"
